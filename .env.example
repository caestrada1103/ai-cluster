# AI Cluster Environment Variables
# Copy this file to .env and adjust as needed

# --- Coordinator Configuration ---
COORDINATOR_HOST=0.0.0.0
COORDINATOR_PORT=8000
DISCOVERY_METHOD=mdns  # Options: mdns, static

# --- Worker Configuration ---
# Worker 1 (AMD)
WORKER_1_ID=amd-gpu-0
WORKER_1_PORT=50051
WORKER_1_METRICS=9091
WORKER_1_GPU_IDS=0

# Worker 2 (NVIDIA)
WORKER_2_ID=nvidia-gpu-0
WORKER_2_PORT=50052
WORKER_2_METRICS=9092
WORKER_2_GPU_IDS=0

# --- Shared Configuration ---
RUST_LOG=info
HF_TOKEN=  # HuggingFace Token for gated models (Llama 3)
