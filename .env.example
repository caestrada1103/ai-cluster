# AI Cluster Environment Configuration
# ======================================
# Copy this file to .env and adjust for your setup.

# ── Worker ────────────────────────────────────────────────────────────────────

# Number of GPU workers to launch (one per GPU)
GPU_COUNT=1

# GPU index for the default worker (0-based)
GPU_INDEX=0

# Base ports (each GPU worker offsets by its GPU_INDEX)
GRPC_BASE_PORT=50051
GRPC_PORT=50051
METRICS_BASE_PORT=9091
METRICS_PORT=9091

# HuggingFace Hub token for gated model downloads
HF_TOKEN=

# Logging level
RUST_LOG=info

# GPU memory per worker (in GB)
GPU_VRAM_GB=6

# ── Coordinator ───────────────────────────────────────────────────────────────

# Comma-separated list of valid API keys (required when enable_auth: true)
COORDINATOR_API_KEYS=

# Secret used to sign JWT tokens (required when enable_auth: true)
COORDINATOR_JWT_SECRET=

# Allowed CORS origins, comma-separated. Restrict in production.
# Example: COORDINATOR_CORS_ORIGINS=https://myapp.example.com
COORDINATOR_CORS_ORIGINS=*

# ── Monitoring ────────────────────────────────────────────────────────────────

# Grafana admin credentials (GRAFANA_ADMIN_PASSWORD is required — no default)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=

# ── Integrations ─────────────────────────────────────────────────────────────

# API key passed to Open-WebUI for calls to the coordinator's /v1 endpoint
OPENAI_API_KEY=

# PostgreSQL connection string (required only if persistence is enabled)
# Example: postgresql://user:password@localhost:5432/ai-cluster
DATABASE_URL=